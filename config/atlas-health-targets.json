{
  "version": 1,
  "schedule": {
    "cron": "0 16 * * 1-5",
    "timezone": "America/New_York",
    "runDays": ["monday", "tuesday", "wednesday", "thursday", "friday"],
    "note": "ATLAS cross-project health sweep runs weekdays at 12:00 PM Eastern while New York observes daylight time. The DiscordOS runtime cron remains daily; ATLAS watch skips weekends to reduce cross-project Vercel usage."
  },
  "targets": [
    {
      "id": "discordos-runtime",
      "label": "DiscordOS runtime",
      "owner": "DiscordOS",
      "url": "https://fawxzzy-discordos.vercel.app/api/runtime-health",
      "kind": "json-ok",
      "critical": true
    },
    {
      "id": "foundation-web",
      "label": "Foundation console",
      "owner": "Foundation",
      "url": "https://fawxzzy-foundation.vercel.app",
      "kind": "http-ok",
      "critical": true
    },
    {
      "id": "fitness-web",
      "label": "Fitness app",
      "owner": "Fitness",
      "url": "https://fawxzzy-fitness-local.vercel.app",
      "kind": "http-ok",
      "critical": true
    },
    {
      "id": "trove-web",
      "label": "Trove app",
      "owner": "Trove",
      "url": "https://fawxzzy-trove.vercel.app",
      "kind": "http-ok",
      "critical": true
    },
    {
      "id": "mazer-web",
      "label": "Mazer app",
      "owner": "Mazer",
      "url": "https://fawxzzy-mazer.vercel.app",
      "kind": "http-ok",
      "critical": true
    }
  ]
}
