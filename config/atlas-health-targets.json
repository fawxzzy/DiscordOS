{
  "version": 1,
  "schedule": {
    "cron": "0 16 * * *",
    "timezone": "America/New_York",
    "note": "Runs at 12:00 PM Eastern while New York observes daylight time. Twice-daily 12:00 AM and 12:00 PM cadence requires a Vercel plan above Hobby."
  },
  "targets": [
    {
      "id": "discordos-runtime",
      "label": "DiscordOS runtime",
      "owner": "DiscordOS",
      "url": "https://fawxzzy-discordos.vercel.app/api/runtime-health",
      "kind": "json-ok",
      "critical": true
    },
    {
      "id": "foundation-web",
      "label": "Foundation console",
      "owner": "Foundation",
      "url": "https://fawxzzy-foundation.vercel.app",
      "kind": "http-ok",
      "critical": true
    },
    {
      "id": "fitness-web",
      "label": "Fitness app",
      "owner": "Fitness",
      "url": "https://fawxzzy-fitness-local.vercel.app",
      "kind": "http-ok",
      "critical": true
    },
    {
      "id": "trove-web",
      "label": "Trove app",
      "owner": "Trove",
      "url": "https://fawxzzy-trove.vercel.app",
      "kind": "http-ok",
      "critical": true
    },
    {
      "id": "mazer-web",
      "label": "Mazer app",
      "owner": "Mazer",
      "url": "https://fawxzzy-mazer.vercel.app",
      "kind": "http-ok",
      "critical": true
    }
  ]
}
